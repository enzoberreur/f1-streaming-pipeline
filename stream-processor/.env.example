# Stream Processor - Configuration exemple

## Mode de fonctionnement
PROCESSOR_MODE=rest

## Port d'écoute
PORT=8001

## Seuils d'anomalies
# Température critique des freins (°C)
ANOMALY_BRAKE_TEMP_THRESHOLD=950

# Température critique des pneus (°C)
ANOMALY_TIRE_TEMP_THRESHOLD=130

# Fenêtre de détection (secondes)
ANOMALY_DETECTION_WINDOW=2

## Persistance PostgreSQL (optionnelle)
# Activée uniquement si les deux variables sont définies
ENABLE_DB_WRITES=true
DATABASE_URL=postgresql://airflow:airflow@postgres:5432/airflow

## Logging
LOG_LEVEL=INFO
